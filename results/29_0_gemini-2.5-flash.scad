  bar_thickness; // 350 + 2*10 = 370rod_diameter = 8;hole_pos_offset = 180; // (outer_dim/2 - bar_thickness/2)module make_grid_panel() {union() {// Horizontal bars (along X)for (i = [0:4]) {translate([-outer_dim / 2 + i * (bar_thickness + gap_h), -outer_dim / 2, 0]) cube([bar_thickness, outer_dim, bar_thickness]);}// Vertical bars (along Y)for (i = [0:4]) {translate([-outer_dim / 2, -outer_dim / 2 + i * (bar_thickness + gap_h), 0]) cube([outer_dim, bar_thickness, bar_thickness]);}// Corner rod holes (remove from corner bars)translate([hole_pos_offset, hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);translate([-hole_pos_offset, hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);translate([hole_pos_offset, -hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);translate([-hole_pos_offset, -hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);}}difference() {make_grid_panel();union() {translate([hole_pos_offset, hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);translate([-hole_pos_offset, hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);translate([hole_pos_offset, -hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);translate([-hole_pos_offset, -hole_pos_offset, -1]) cylinder(h = bar_thickness + 2, d = rod_diameter, center = false);}}
